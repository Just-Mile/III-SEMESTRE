#include <iostream>
using namespace std;

int main()
{
    int n = 12;
    char* A = new char[n]{' ', ' ', 'j','a','v', 'a', ' ','+', ' ', ' ', ' ', ' '};
    //contar espacios der e izq
    int spc_l = 0;
    char * ini_w = A;
    for(; ini_w < A + n && *ini_w == ' '; ini_w++){
        spc_l++;
    }
    cout<<spc_l;
    cout<< *ini_w<<endl;
    
    int spc_r = 0;
    char* end_w = A+n - 1;
    for(; end_w >= A && *end_w == ' '; end_w--){
        spc_r++;
    }
    cout<<spc_r;
    cout<<*end_w<<endl;
    
    
    int eq_spc = (spc_l + spc_r)/2;
    if (spc_l > eq_spc){
        cout<<"A la izq";
        for(char* lector = ini_w,*write = A + eq_spc; lector <= end_w; *write++ = *lector++);
        for( ; end_w < A + n; *end_w++ = ' ');
    }
    else if(spc_l<eq_spc){
        cout<<"A la der";
        for(char* lector = end_w,*write = A + n- eq_spc - 1; lector >= ini_w; *write-- = *lector--);
        for( ; ini_w >= A; *ini_w-- = ' ');
    }
    else{
        cout<<"Ya está centrado";
    }
    
    for(char* p = A; p < A + n ; p++) cout<<*p<< ", ";
    return 0;
}
