//FUNCTION OBJECT || Smart Function
// Objeto que representa una función
// Aseguramos que será eficiente.
// VENTAJA:
//	posibilidad de guardar datos en una función

//CLASE COMUN
class miFuncion{
	private:
		int x;
		int y;
	public:
		miFuncion(int a, int b):x(a), y(b){};
		int operator()(int z){ //LA DIEFERENCIA Sobrecarga del operador paréntesis,
			return x*y*z;
		} 

};

void main(){
	miFuncion F1(5, 2);
	std::cout<<F1(3); //Funcion que llama a los paréntesis
			  // Entonces, ya no tengo que indicar cual es x, y, sino SOLO lo que cambia
			  //Imprimirá 30

