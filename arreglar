#include <iostream>

void Imprimir(int a[], int n){
    std::cout<< "[";
    for(int i =0; i<n;i++){
        std::cout<< a[i] << " ";
    }
    
    std::cout<< "]"<<std::endl;
}

bool Entero_consecutivo(int a[], int n){
    for(int i=0; i < n-1;i++){
        if(a[i]==a[i+1]){
            return true;
        }
    }
    return false;
}


int main()
{
    int n = 10;
    int a[n] = {1, 4, 2, 2, 1, 1, 4, 3, 3, 4};
    int indice = 0;
    
    std::cout<< std::endl;
    bool Seguir = Entero_consecutivo(a, n);
    
    
    
    while(Seguir == true){
        std::cout<<"entro al bucle"<<std::endl;
        Imprimir(a, n);
        std::cout<<n<<std::endl;
        
        
       for(int i=0; i < n; ){
        if(i<n-1 && a[i]==a[i+1]){
            i+=2;
        } else{
            a[indice] = a[i];
            indice++;
            i++;
          }
        }
    
        for(int i=indice; i<n; i++){
            a[i]=0;
        }
    std::cout<<"sigo en el bucle"<<std::endl;
        Imprimir(a, n);
      
    
       Seguir = Entero_consecutivo(a, n);
       std::cout<<Seguir<<std::endl;
       
    }

    return 0;
}
