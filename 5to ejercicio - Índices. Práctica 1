#include <iostream>

int main()
{
    int tam = 7;
    int n=3;
    int a[tam] = {3, 3, 2, 6, 9, 8, 6};
    int llenar = tam-n+1;
    
    std::cout<< "[";
    for(int i =0; i<tam;i++){
        std::cout<< a[i]<< " ";
    }
    
    std::cout<< "]" << std::endl;
    
    
    for(int i=0; i<llenar;i++){
        int suma=0;
        for(int j=0; j<n; j++){
            suma+=a[i+j];
        }
        a[i]=suma;
    }
    
    
    for(int i=llenar; i<tam;i++){
        a[i]=0;
    }
    
    
    std::cout<< "[";
    for(int i =0; i<tam;i++){
        std::cout<< a[i]<< " ";
    }
    std::cout<< "]" << std::endl;
    return 0;
}
