#include <iostream>

int main()
{
    int tam = 11;
    char A[11] ={'c','+','+',' ','j','a','v','a',' ',' ',' '};
    int i = tam-1;
    int espacios = 0; 
    
    //CONTADOR
    while(A[i]== ' '){
        espacios ++;
        i--;
    }
    
    for(int i=tam-1-espacios;i>=0; i--){
        A[i+espacios] = A[i];
        std::cout<<A[i]<< ", ";
    }
    
    std::cout<< "\n";
    std::cout<<espacios<<"\n";
    
    
    for(int i=0; i<tam; i++){
       std::cout<<A[i]<<", ";
    }
    std::cout<<"\n";
    

    return 0;
}
