#include <iostream>

int main()
{
    int n = 7;
    int a[n] = {3, 3, 2, 6, 9, 8, 6};
    int indice = 0;
    
    std::cout<< "[";
    for(int i =0; i<n;i++){
        std::cout<< a[i]<< " ";
    }
    
    std::cout<< "]" << std::endl;

    for(int i=0; i < n; ){
//std::cout<< a[i]<< " vs " << a[indice] << std::endl;
        if(i<n-1 && a[i]==a[i+1]){
            i+=2;
        } else{

            //std::cout<< a[i]<< " vs " << a[i+1] << std::endl;
            a[indice] = a[i];
         
           //std::cout<<"Indice: "<< indice<< std::endl;
            indice++;
           // std::cout<<"Indice+1: "<< indice<< std::endl
           i++;
           
        }

    }
    
    for(int i=indice; i<n; i++){
        a[i]=0;
    }
    
    std::cout<< "[";
    for(int i =0; i<n;i++){
        std::cout<< a[i] << " ";
    }
    
    std::cout<< "]";

    return 0;
}
