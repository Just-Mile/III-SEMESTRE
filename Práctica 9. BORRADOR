template<class T>
	std::vector<int> find_matching(std::vector<int> v,T f){
	std::vector<int> res;
	std::vector<int>::iterator it=v.begin();
	std::vector<int>::iterator end=v.end();
	while(it!= end)
	{
		if(f(*it))
			res.push_back(*it);
		it++;
	}
	return res;
}
	

