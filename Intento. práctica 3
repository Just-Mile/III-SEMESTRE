#include <iostream>
using namespace std;
int main()
{
    int n = 11;
    char* A = new char[n]{' ', ' ', 'c', '+', '+',' ', 'j', 'a', 'v', ' ', 'a'};
    int spc = 0;
    
    for (char* ptr = A; ptr< A+n; ptr++){
        if(*ptr == ' ')spc++;
    }
    cout<<"Spces: "<<spc<<endl;
    
    int words = 0;
    for (char* ptr = A; ptr< A+n-1; ptr++){
        if(*ptr == ' ' && (*(ptr+1) != ' ')) words++;
    }
    cout<<"Palabras: "<<words<<endl;
    int jumps = words - 1;
    int eq_spc = spc/jumps;
    cout<<"Saltos: "<<jumps<<endl;
    cout<<"Cant de spc por salto: "<< eq_spc<<endl;
    
    
    char* reader{nullptr};
    
    for(char* p = A; p < A+n; p++){
        if(*p !=' '){
            reader = p;
            break;
        }
    }
    
    for(char* writer = A; writer < A + n; ){
        for ( ; reader < A+n && *reader!= ' '; *writer++ = *reader++);  // + límite
        while(reader < A+n && *reader==' '){                             // + límite
            reader++;
        }
        for (int i =0; i<eq_spc; i++){
            *writer= ' ';
            writer++;
        }
    
        cout<<*writer;
    }
    
    
    cout<<endl;
    
    
    for(char* p= A; p < A+n; p++) cout<<*p<<", ";
    
    
    return 0;
    
    
}
