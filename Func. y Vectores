vector<int> f_match(vector<int> v,bool(*f)(int,int)){
    vector<int> res;
    vector<int>:: iterator it=v.begin();
    vector<int>:: iterator end=v.end();
    while(it!=end){
        if(f(*it,2)){
            res.push_back(*it);
        }
        it++;
    }
    return res;

}

