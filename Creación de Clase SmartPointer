#include <iostream>
#include <utility>
class SmartPointer{
	private:
		int* ptr;
	public:
		explicit SmartPointer(int* p = nullptr): ptr(p){}
//				      '''''''''''''''''
//				CONSTRUCTOR: recibe un puntero

		~SmartPointer(){delete ptr;}
//				'''''''''''
//				DESTRUCTOR

		SmartPointer(const SmartPointer&) = delete; //Constructor de copia el cual no puede existir en un unique pointer
		
		int& operator*(){return *ptr;} //Operador binario que no recibe nada, trabaja sobre el objeto

		int* operator->(){return ptr;} //¿Qué significa?
		SmartPointer& operator(SmartPointers&& other) noexcept{
			delete ptr;
			ptr = other.ptr;
			other.ptr = nullptr;
			std::cout<<"operator = de movimiento";
			return *this;
		
		}

		void Imprimir(){
		std::cout<<*ptr<<"\n";
		}


};

int main()
{
	SmartPointer p(new int(10));
	std::cout<<*p->imprimir()<<"\n";
return 0;
}
