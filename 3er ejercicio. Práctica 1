#include <iostream>

void Repetir(int* arr, int n, int tam){
    int* posicion = arr + tam-1; //desde atras
    int* indice = arr;
    
    int contador = 0;
    while (indice < arr + tam && *indice > 0) {
        contador++;
        indice++;
    }
    
    indice = arr + contador - 1;
    
    while (indice >= arr) {
        for (int i = 0; i < n; i++) {
            *posicion = *indice;  // posicion escribe
            posicion--;
        }
        indice--;
    }
    
    for(int* p = arr; p<arr+tam; p++){
        std::cout<< *p << " ";
    }
    std::cout<<std::endl;
}



int main(){
    int arr[] = {1, 3, 2, 4, 0, 0, 0, 0, 0, 0, 0, 0};
    int n = 3;
    int tam = 12;
    
    std::cout << "Array original: ";
    for (int* p = arr; p < arr + tam; p++) {
        std::cout << *p<< " ";
    }
    std::cout << "\n" << std::endl;
    
    Repetir(arr, n, tam); //LALALALLAA
    

    return 0;
}
