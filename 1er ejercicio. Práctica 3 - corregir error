#include <iostream>

void contar_espacios(char* A, int &n){
    int espac_der = 0;
    int espac_izq = 0;
    
    char* p = A;
    while(p<A+n-1){
        if(*p == ' ') espac_der++;
        else break;
        p++;
    }
    char* p_inicio = p; 
  
    char* q = A+n-1;
    while(q>=A){
        if(*q == ' ') espac_izq++;
        else break;
        q--;
    }
    char* p_final = q;
    int esp_ig=(espac_der + espac_izq)/2;
    
    
    
    char* escritor = A;         
    char* lector = p_inicio;    
    
    for(int i = 0; i < esp_ig; i++){
        *escritor = ' ';
        escritor++;
    }
    
    while(lector <= p_final){
        *escritor = *lector;
        escritor++;
        lector++;
    }
    
    int espacios_restantes = (espac_der + espac_izq) - esp_ig;
    for(int i = 0; i < espacios_restantes; i++){
        *escritor = ' ';
        escritor++;
    }
    
    // Mostrar resultado
    std::cout << "Centrado: ";
    for(char* r = A; r < A+n; r++){
        std::cout << *r<< ',';
    }
    std::cout << std::endl;
}

int main()
{
    int n = 12;
    char A[n]={' ',' ',' ',' ','j', 'a', 'v', 'a', ' ', '+', ' ', ' '};
    contar_espacios(A, n);
    return 0;
}
